  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/hadi/.claude/hooks/notify.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/final-review.sh",
            "statusMessage": "Running final project review..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/hadi/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/web-lint.sh",
            "statusMessage": "Linting..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/security-scan.sh",
            "statusMessage": "Security scan..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hook_event_name\": \"idle_prompt\"}' | bash /Users/hadi/.claude/hooks/notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/hadi/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "warp@claude-code-warp": true
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "voiceEnabled": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "autoDreamEnabled": true
}
