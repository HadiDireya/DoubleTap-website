{
  "name": "doubletap-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply doubletap --local",
    "db:migrate:remote": "wrangler d1 migrations apply doubletap --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "better-auth": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
